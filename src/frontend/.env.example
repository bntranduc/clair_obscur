# Copier vers .env.local (local) ou définir les mêmes clés dans Amplify → Hosting → Variables d’environnement.

# --- Option A : accès direct au backend (local, ou HTTPS→HTTPS) ---
NEXT_PUBLIC_DASHBOARD_API_URL=http://127.0.0.1:8010

# --- Option B : Amplify (HTTPS) + EC2 API en HTTP — évite le mixed content navigateur ---
# NEXT_PUBLIC_DASHBOARD_API_PROXY=1
# DASHBOARD_API_URL=http://EC2_IP_PUBLIQUE:8010
# (DASHBOARD_API_URL est lue côté serveur uniquement ; ne pas préfixer NEXT_PUBLIC_)
