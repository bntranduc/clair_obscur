# Copier vers .env.local (développement) ou renseigner les mêmes clés dans
# Amplify → Hosting → Variables d’environnement (rebuild après modification).

# =============================================================================
# Développement local — backend sur ta machine (8010)
# =============================================================================
NEXT_PUBLIC_DASHBOARD_API_URL=http://127.0.0.1:8010
# Ne pas activer le proxy en local sauf test explicite :
# NEXT_PUBLIC_DASHBOARD_API_PROXY=0

# =============================================================================
# Développement local — backend déjà sur EC2 (test depuis npm run dev)
# Navigateur http→http OK. Remplace par ton DNS ou IP publique EC2.
# =============================================================================
# NEXT_PUBLIC_DASHBOARD_API_URL=http://ec2-XX-XX-XX-XX.eu-west-3.compute.amazonaws.com:8010

# =============================================================================
# Production Amplify (site en HTTPS) + API EC2 en HTTP
# Le navigateur appelle ton domaine Amplify ; Next.js proxifie vers EC2 (pas de mixed content).
# =============================================================================
# NEXT_PUBLIC_DASHBOARD_API_PROXY=1
# DASHBOARD_API_URL=http://ec2-XX-XX-XX-XX.eu-west-3.compute.amazonaws.com:8010
# (sans NEXT_PUBLIC_ — lu uniquement par la route /api/dashboard-proxy côté serveur)

# =============================================================================
# Backend EC2 — CORS si tu appelles l’API directement depuis le navigateur (sans proxy)
# À exporter sur l’EC2 / Docker : liste d’origines séparées par des virgules.
# Exemple : https://main.xxxxx.amplifyapp.com,http://localhost:3000
# =============================================================================
# (côté repo backend / conteneur dashboard, pas dans ce fichier Next)
