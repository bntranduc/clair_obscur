# Obligatoire : pas de fallback localhost dans le code.
# Obligatoire : pas de fallback localhost dans le code.
# Copier vers .env.local (dev) ou définir dans Amplify → Hosting → Variables (rebuild).

# -----------------------------------------------------------------------------
# Option directe — navigateur → EC2 (OK depuis npm run dev en http://localhost:3000)
# Remplace par ton DNS / IP publique réelle (sans slash final).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DASHBOARD_API_URL=http://ec2-XX-XX-XX-XX.eu-west-3.compute.amazonaws.com:8010

# -----------------------------------------------------------------------------
# Option Amplify (HTTPS) — mixed content évité : proxy Next.js → EC2
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DASHBOARD_API_PROXY=1
# NEXT_PUBLIC_DASHBOARD_API_URL=          # laisser vide ou absent si tout passe par proxy
# DASHBOARD_API_URL=http://ec2-XX-XX-XX-XX.eu-west-3.compute.amazonaws.com:8010

# -----------------------------------------------------------------------------
# Backend EC2 — CORS (appels navigateur → API, pas via proxy)
# Docker / EC2 : variable DASHBOARD_CORS_ORIGINS=liste séparée par virgules.
# Le backend ajoute automatiquement http://localhost:3000 si la liste est restreinte.
# Prod stricte sans localhost : DASHBOARD_CORS_STRICT=1 sur le conteneur dashboard.
# -----------------------------------------------------------------------------
