{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BedrockInferenceProfile",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": "arn:aws:bedrock:eu-west-3:534727954026:inference-profile/eu.anthropic.claude-opus-4-6-v1"
    },
    {
      "Sid": "SqsConsumeRawLogsEvents",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueUrl",
        "sqs:GetQueueAttributes",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:eu-west-3:534727954026:clair-raw-logs-events"
    },
    {
      "Sid": "S3ListPredictionsPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::model-attacks-predictions",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["predictions/*"]
        }
      }
    },
    {
      "Sid": "S3ReadWritePredictionsObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::model-attacks-predictions/predictions/*"
    },
    {
      "Sid": "S3ListLogsPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::clair-obscure-raw-logs",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["raw/*"]
        }
      }
    },
    {
      "Sid": "S3GetLogsObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::clair-obscure-raw-logs/raw/*"
    }
  ]
}
