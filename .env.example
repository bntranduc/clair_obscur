# Copie : cp .env.example .env  (le fichier .env reste ignoré par git)
#
# Modèle Bedrock (serve_app, predict) : utilise le profil AWS CLI / SSO, pas de clés dans .env.
#   aws sso login --profile bao
#   export AWS_PROFILE=bao   # ou AWS_PROFILE=bao dans ce fichier après load_dotenv (scripts)
AWS_PROFILE=
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3

# Optionnel (serve_app lit ces variables d'environnement)
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096

# Worker SQS (docker compose --profile sqs) — URL exacte de ta file Standard
# SQS_QUEUE_URL=https://sqs.eu-west-3.amazonaws.com/534727954026/clair-raw-logs-events
# PREDICT_MODE=inline
# OUTPUT_BUCKET=model-attacks-predictions
# OUTPUT_PREFIX=predictions/

# Autres scripts (S3 / OpenSearch avec clés classiques) : src/backend/.env.aws
