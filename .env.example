# Copier vers .env (non versionné) : cp .env.example .env
# Renseigner les valeurs marquées. Sur EC2 avec rôle IAM : ne pas définir AWS_PROFILE (ni chaîne vide).

# --- AWS (tous les services Python / Docker) ---
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3
# Profil CLI / SSO (local uniquement). Sur EC2 avec rôle : omettre cette variable.
# AWS_PROFILE=mon-profil-sso
# Optionnel : clés explicites (déconseillé en prod ; préférer rôle ou SSO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- API dashboard ``api.main`` (uvicorn / Docker backend, défaut port 8020) ---
API_PORT=8020
# Jeu d’alertes (JSON) pour ``GET /api/v1/alerts`` et l’outil agent ``get_all_alerts`` — chemin absolu ou relatif à la racine du dépôt.
# Défaut : ``database/alerts.json``. Exemple d’override (jeu de démo) :
# ALERTS_DATASET_PATH=datasets/fake_data/predictions_all_attack_types.json
RAW_LOGS_BUCKET=clair-obscure-raw-logs
RAW_LOGS_PREFIX=raw/opensearch/logs-raw/
# Logs (onglet dashboard) : ``GET /api/v1/logs/dynamodb`` — identifiants AWS **uniquement** côté serveur (rôle / .env).
# Même logique de session que ``test.py`` : ``AWS_PROFILE`` ou ``AWS_ACCESS_KEY_ID`` / ``AWS_SECRET_ACCESS_KEY`` / ``AWS_SESSION_TOKEN``.
DYNAMODB_TABLE=normalized-logs
# Partition (même défaut que ``test.py`` si tout est vide : RAW#clair-obscure-raw-logs#D#2026-01-12)
# DYNAMODB_PK=RAW#clair-obscure-raw-logs#D#2026-01-12
# DYNAMODB_LOGS_PK=RAW#clair-obscure-raw-logs#D#2026-01-12
# DYNAMODB_LOGS_DAY=2026-01-12
# DYNAMODB_LOGS_DEFAULT_PK=RAW#clair-obscure-raw-logs#D#2026-01-12
# Frontend (optionnel) : passer ``pk`` en query si l’API n’a pas les variables ci-dessus
# NEXT_PUBLIC_DYNAMODB_PK=RAW#clair-obscure-raw-logs#D#2026-01-12
# Analytics onglet « Général » : ``GET /api/v1/analytics/dynamodb?max_items=15000`` (même ``pk`` / session AWS)
# Logs S3 (ancienne route) : ``GET /api/v1/logs/normalized?skip=&limit=`` — creds en query optionnels (déconseillé)
# Chat Bedrock : ``POST /api/v1/chat`` — champs optionnels aws_access_key_id / aws_secret_access_key / aws_session_token / region.

# OpenSearch (SIEM). À adapter ; ne pas committer de vrai mot de passe.
OPENSEARCH_HOST=
OPENSEARCH_PORT=443
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_INDEX=logs-raw
OPENSEARCH_TIMESTAMP_FIELD=timestamp

# Chat dashboard (Bedrock) — mêmes variables que le modèle si tu veux un seul modèle
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096
# BEDROCK_CHAT_MAX_TOKENS=4096
# BEDROCK_CHAT_SYSTEM_PROMPT=

# Agentic (OpenRouter) — requis pour ``/api/v1/agentic``
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AGENTIC_MAX_SESSIONS=200
# Limite les tours agent (outils + réponses). Défaut code : 40 ; surcadable par ``config.toml``.
# AGENTIC_MAX_TURNS=32
# AGENTIC_MAX_COMPLETION_TOKENS=
# Coupe le flux SSE si aucun chunk pendant N secondes (anti-blocage réseau).
# AGENTIC_STREAM_IDLE_SEC=120
# Réflexion modèle (OpenRouter) : off | low | medium | high | ou entier = max_tokens reasoning.
# AGENTIC_REASONING_EFFORT=low
# AGENTIC_REASONING_FORCE=

# --- API modèle ``api.model_app`` / ``model_api`` (défaut port 8080 en doc) ---
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096

# --- Worker SQS → prédictions S3 (``sqs_predict_worker``) ---
# SQS_QUEUE_URL=https://sqs.eu-west-3.amazonaws.com/COMPTE/clair-raw-logs-events
# PREDICT_MODE=http
# PREDICT_API_URL=http://127.0.0.1:8080
# PREDICT_TIMEOUT_SEC=900
# OUTPUT_BUCKET=model-attacks-predictions-tmp
# OUTPUT_PREFIX=predictions/
# SQS_WAIT_TIME_SECONDS=20
# SQS_VISIBILITY_TIMEOUT=900
# MAX_SQS_MESSAGES=5

# --- Lecture alertes S3 (dashboard / scripts) ---
# PREDICTIONS_BUCKET=model-attacks-predictions-tmp
# PREDICTIONS_PREFIX=predictions/

# --- Lambda ``raw_logs_to_predict`` (souvent dans la console Lambda, pas ce fichier) ---
# MODEL_API_URL=http://127.0.0.1:8080
# OUTPUT_BUCKET=alerts-predictions
# OUTPUT_PREFIX=predictions/
# PREDICT_TIMEOUT_SEC=120

# --- Next.js (``src/frontend``) ---
# URL de base de l’API FastAPI (dashboard, agentic, logs) — priorité sur le défaut local 8020.
# NEXT_PUBLIC_API_BASE=https://votre-api.example
# (alias supporté) NEXT_PUBLIC_MODEL_API_URL=https://votre-api.example
# Le front n’envoie **pas** d’identifiants AWS pour les logs : l’API lit S3 via rôle IAM ou ``AWS_*`` du conteneur.
# FRONTEND_API_PROXY_TARGET=…
# FRONTEND_MODEL_PROXY_TARGET=…
