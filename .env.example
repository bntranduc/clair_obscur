# Copier vers .env (non versionné) : cp .env.example .env
# Renseigner les valeurs marquées. Sur EC2 avec rôle IAM : ne pas définir AWS_PROFILE (ni chaîne vide).

# --- AWS (tous les services Python / Docker) ---
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3
# Profil CLI / SSO (local uniquement). Sur EC2 avec rôle : omettre cette variable.
# AWS_PROFILE=mon-profil-sso
# Optionnel : clés explicites (déconseillé en prod ; préférer rôle ou SSO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- API dashboard ``api.main`` (uvicorn / Docker backend, défaut port 8020) ---
API_PORT=8020
RAW_LOGS_BUCKET=clair-obscure-raw-logs
RAW_LOGS_PREFIX=raw/opensearch/logs-raw/
# Logs normalisés : ``GET /api/v1/logs/normalized?skip=&limit=`` — sans creds dans l’URL si l’API utilise le rôle IAM
# (recommandé). Debug curl avec creds en query : utiliser ``curl -G`` + ``--data-urlencode`` (voir doc AWS).
# Chat Bedrock : ``POST /api/v1/chat`` — champs optionnels aws_access_key_id / aws_secret_access_key / aws_session_token / region.

# OpenSearch (SIEM). À adapter ; ne pas committer de vrai mot de passe.
OPENSEARCH_HOST=
OPENSEARCH_PORT=443
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=true
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_INDEX=logs-raw
OPENSEARCH_TIMESTAMP_FIELD=timestamp

# Chat dashboard (Bedrock) — mêmes variables que le modèle si tu veux un seul modèle
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096
# BEDROCK_CHAT_MAX_TOKENS=4096
# BEDROCK_CHAT_SYSTEM_PROMPT=

# Agentic (OpenRouter) — requis pour ``/api/v1/agentic``
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AGENTIC_MAX_SESSIONS=200
# AGENTIC_MAX_COMPLETION_TOKENS=
# AGENTIC_STREAM_IDLE_SEC=
# AGENTIC_REASONING_EFFORT=
# AGENTIC_REASONING_FORCE=

# --- API modèle ``api.model_app`` / ``model_api`` (défaut port 8080 en doc) ---
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096

# --- Worker SQS → prédictions S3 (``sqs_predict_worker``) ---
# SQS_QUEUE_URL=https://sqs.eu-west-3.amazonaws.com/COMPTE/clair-raw-logs-events
# PREDICT_MODE=http
# PREDICT_API_URL=http://127.0.0.1:8080
# PREDICT_TIMEOUT_SEC=900
# OUTPUT_BUCKET=model-attacks-predictions-tmp
# OUTPUT_PREFIX=predictions/
# SQS_WAIT_TIME_SECONDS=20
# SQS_VISIBILITY_TIMEOUT=900
# MAX_SQS_MESSAGES=5

# --- Lecture alertes S3 (dashboard / scripts) ---
# PREDICTIONS_BUCKET=model-attacks-predictions-tmp
# PREDICTIONS_PREFIX=predictions/

# --- Lambda ``raw_logs_to_predict`` (souvent dans la console Lambda, pas ce fichier) ---
# MODEL_API_URL=http://127.0.0.1:8080
# OUTPUT_BUCKET=alerts-predictions
# OUTPUT_PREFIX=predictions/
# PREDICT_TIMEOUT_SEC=120

# --- Next.js (``src/frontend``) ---
# URL de l’API FastAPI (défaut EC2 dans ``src/frontend/src/lib/apiBackendUrl.ts``).
# NEXT_PUBLIC_CLAIR_API_BASE=http://13.39.106.74:8020
# Le front n’envoie **pas** d’identifiants AWS pour les logs : l’API EC2 doit lire S3 via rôle IAM ou ``AWS_*`` du conteneur.
# NEXT_PUBLIC_MODEL_API_URL=…
# FRONTEND_API_PROXY_TARGET=…
# FRONTEND_MODEL_PROXY_TARGET=…
