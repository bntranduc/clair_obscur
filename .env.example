# Copie : cp .env.example .env  (le fichier .env reste ignoré par git)
#
# AWS — obligatoire pour les scripts/tests qui appellent Bedrock sans rôle IAM,
# ou pour compléter la chaîne boto3 en local. Sur EC2 avec instance profile, tu peux laisser vide.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3
# AWS_PROFILE=

# API modèle (serve_app) — optionnel (défauts dans le code sinon)
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096

# Autres scripts : voir src/backend/.env.aws pour S3 / OpenSearch (bootstrap_checkpoint, check_s3_logs, …)
