# Copie : cp .env.example .env  (le fichier .env reste ignoré par git)
#
# Modèle Bedrock (serve_app, predict) : utilise le profil AWS CLI / SSO, pas de clés dans .env.
#   aws sso login --profile bao
#   export AWS_PROFILE=bao   # ou AWS_PROFILE=bao dans ce fichier après load_dotenv (scripts)
AWS_PROFILE=
AWS_REGION=eu-west-3
AWS_DEFAULT_REGION=eu-west-3

# API HTTP logs S3 (`scripts/run_api.sh`) — boto3 utilise AWS_PROFILE si défini
# RAW_LOGS_BUCKET=clair-obscure-raw-logs
# RAW_LOGS_PREFIX=raw/opensearch/logs-raw/
#
# Alertes / prédictions API (`run_api.sh`) — défaut tmp ; repasser en prod :
# PREDICTIONS_BUCKET=model-attacks-predictions
# PREDICTIONS_BUCKET_TMP=model-attacks-predictions-tmp
# PREDICTIONS_PREFIX=predictions/
# API_PORT=8020
# Next.js : proxy navigateur vers cette URL (dev local)
# FRONTEND_API_PROXY_TARGET=http://127.0.0.1:8020
# Front qui parle à une API distante sans rewrite :
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8020
#
# Modèle /predict (serve_app). Sans NEXT_PUBLIC_MODEL_API_URL : proxy Next ``/bff-model`` → cible
# (défaut dans ``next.config.ts`` : EC2 ; surcharge pour modèle local) :
# FRONTEND_MODEL_PROXY_TARGET=http://127.0.0.1:8080
# FRONTEND_MODEL_PROXY_TARGET=http://13.39.21.85:8080
# Appel navigateur direct (CORS activé sur serve_app) :
# NEXT_PUBLIC_MODEL_API_URL=http://13.39.21.85:8080

# Optionnel (serve_app lit ces variables d'environnement)
# BEDROCK_MODEL_ID=eu.anthropic.claude-opus-4-6-v1
# BEDROCK_MAX_TOKENS=4096
#
# Chat dashboard : ``POST /api/v1/chat`` (même BEDROCK_MODEL_ID que ci-dessus si défini)
# BEDROCK_CHAT_MAX_TOKENS=4096
# Surcharge du prompt système (défaut : ``backend.aws.bedrock.platform_prompt.CHAT_SYSTEM_PROMPT``)
# BEDROCK_CHAT_SYSTEM_PROMPT=...

# Worker SQS (docker compose --profile sqs) — URL exacte de ta file Standard
# SQS_QUEUE_URL=https://sqs.eu-west-3.amazonaws.com/534727954026/clair-raw-logs-events
# PREDICT_MODE=inline
# OUTPUT_BUCKET=model-attacks-predictions-tmp
# OUTPUT_PREFIX=predictions/

# Autres scripts (S3 / OpenSearch avec clés classiques) : src/backend/.env.aws
